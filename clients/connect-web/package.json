{
  "name": "@repo/connect-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Browser-side gRPC clients generated by buf + connect-es. Same .proto, second transport story — works over HTTP/JSON or gRPC-Web from a browser, no proxy needed.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./orders/v1": {
      "types": "./dist/gen/orders/v1/orders_pb.d.ts",
      "import": "./dist/gen/orders/v1/orders_pb.js"
    },
    "./users/v1": {
      "types": "./dist/gen/users/v1/users_pb.d.ts",
      "import": "./dist/gen/users/v1/users_pb.js"
    },
    "./grpc/health/v1": {
      "types": "./dist/gen/grpc/health/v1/health_pb.d.ts",
      "import": "./dist/gen/grpc/health/v1/health_pb.js"
    }
  },
  "files": ["dist", "src/gen"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.3",
    "@connectrpc/connect": "^2.1.0",
    "@connectrpc/connect-web": "^2.1.0"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.2.3",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
