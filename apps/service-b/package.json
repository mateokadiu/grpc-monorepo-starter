{
  "name": "@repo/service-b",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reference gRPC consumer. NestJS 11 + Fastify HTTP server on :3001 that delegates REST endpoints to service-a's OrdersService over gRPC, including server-streaming for /orders.",
  "scripts": {
    "build": "tsc -b",
    "dev": "node --enable-source-maps --watch dist/main.js",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.2",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@repo/proto-gen": "workspace:*",
    "fastify": "^5.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.10.0",
    "@repo/service-a": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
}
