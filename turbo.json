{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "proto/**"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": { "cache": false, "persistent": true },
    "test": { "dependsOn": ["^build"] },
    "typecheck": { "dependsOn": ["^build"] },
    "lint": {},
    "gen": {
      "inputs": ["../../proto/**", "src/buf-stub.ts", "scripts/**"],
      "outputs": ["src/generated/**"]
    }
  }
}
